generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String
  budget    String?
  message   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  description String?
  imageUrl    String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
}